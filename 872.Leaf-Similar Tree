class Solution {
        
    public boolean leafSimilar(TreeNode root1, TreeNode root2) {
        ArrayList<Integer> list1=new ArrayList<>();
        ArrayList<Integer> list2=new ArrayList<>();
       similartree(root1,list1);
        similartree(root2,list2);
       return list1.equals(list2);
    }
        void similartree(TreeNode root,List<Integer>list){
             if(root==null) return;
             if(root.left==null && root.right==null){
                list.add(root.val);
             }
        
            similartree(root.left,list);
            similartree(root.right,list);
        
    }
}
